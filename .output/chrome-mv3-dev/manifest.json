{
  "manifest_version": 3,
  "name": "JobFill",
  "description": "Autofill job application forms in one click.",
  "version": "1.0.0",
  "short_name": "JobFill",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://api.notion.com/*",
    "https://script.google.com/*",
    "<all_urls>",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobFill"
  },
  "options_ui": {
    "page": "options.html"
  },
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}